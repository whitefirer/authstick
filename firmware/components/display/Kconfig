menu "AuthStick Display"

config DISPLAY_SPI_HOST
    int "SPI host (1=SPI2/FSPI, 2=SPI3)"
    default 1
    range 1 2

config DISPLAY_PIN_SCLK
    int "SCLK pin"
    default 12

config DISPLAY_PIN_MOSI
    int "MOSI pin"
    default 11

config DISPLAY_PIN_DC
    int "DC pin"
    default 10

config DISPLAY_PIN_RST
    int "RST pin"
    default 9

config DISPLAY_PIN_CS
    int "CS pin"
    default 8

config DISPLAY_PIN_BL
    int "Backlight pin"
    default 4

config DISPLAY_WIDTH
    int "Display width"
    default 135

config DISPLAY_HEIGHT
    int "Display height"
    default 240

endmenu
